/* 账单列表页样式 */
.container { padding: 32rpx; min-height: 100vh; background: #F8F8F8; }
.filter-bar { margin-bottom: 24rpx; }
.month-picker { padding: 20rpx; background: white; border-radius: 16rpx; text-align: center; }
.empty { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 120rpx; display: block; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #666; }
.bill-list { display: flex; flex-direction: column; gap: 16rpx; }
.bill-item { display: flex; align-items: center; background: white; padding: 24rpx; border-radius: 16rpx; }
.bill-icon { font-size: 40rpx; margin-right: 16rpx; }
.bill-info { flex: 1; }
.bill-category { display: block; font-size: 28rpx; font-weight: 600; margin-bottom: 4rpx; }
.bill-desc { font-size: 24rpx; color: #999; }
.bill-amount { font-size: 32rpx; font-weight: 700; }
.bill-amount.expense { color: #FF6B9D; }
.bill-amount.income { color: #52C41A; }
