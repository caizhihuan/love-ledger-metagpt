/* 绑定页样式 */
.container { padding: 64rpx 32rpx; background: linear-gradient(180deg, #FFE5EC, #FFF5F7); min-height: 100vh; }
.header { text-align: center; margin-bottom: 64rpx; }
.title { display: block; font-size: 48rpx; font-weight: 700; color: #FF6B9D; margin-bottom: 16rpx; }
.subtitle { font-size: 28rpx; color: #666; }
.bind-options { display: flex; flex-direction: column; gap: 24rpx; }
.option-card { background: white; padding: 32rpx; border-radius: 20rpx; text-align: center; box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.1); }
.option-icon { display: block; font-size: 48rpx; margin-bottom: 16rpx; }
.option-title { display: block; font-size: 32rpx; font-weight: 600; margin-bottom: 8rpx; }
.option-desc { font-size: 24rpx; color: #999; }
.divider { text-align: center; padding: 24rpx 0; color: #999; }
.invite-section, .join-section { text-align: center; padding: 48rpx 0; }
.invite-label { display: block; font-size: 28rpx; color: #666; margin-bottom: 24rpx; }
.invite-code { display: block; font-size: 72rpx; font-weight: 700; letter-spacing: 12rpx; color: #FF6B9D; margin-bottom: 32rpx; font-family: monospace; }
.copy-btn, .join-btn { background: linear-gradient(135deg, #FF6B9D, #FF8E9E); color: white; padding: 20rpx 48rpx; border-radius: 48rpx; margin-bottom: 16rpx; }
.back-btn { background: white; color: #666; padding: 20rpx; border-radius: 48rpx; }
.code-input { width: 100%; font-size: 56rpx; letter-spacing: 16rpx; text-align: center; padding: 24rpx 0; border-bottom: 2rpx solid #f0f0f0; margin-bottom: 32rpx; font-family: monospace; }
