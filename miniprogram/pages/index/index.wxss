/* 恋账 - 记账首页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFE5EC 0%, #FFF5F7 30%, #F8F8F8 100%);
}

.header {
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E9E 100%);
  border-radius: 0 0 48rpx 48rpx;
  color: white;
}

.date-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.month {
  font-size: 32rpx;
  font-weight: 600;
}

.day {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
}

.weekday {
  font-size: 28rpx;
  opacity: 0.9;
}

.summary {
  display: flex;
  gap: 32rpx;
}

.summary-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  padding: 24rpx;
  border-radius: 16rpx;
}

.summary-item .label {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.summary-item .amount {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.quick-add {
  padding: 32rpx;
}

.quick-add .text-input {
  width: 100%;
  padding: 20rpx;
  background: white;
  border-radius: 16rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.ai-btn {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E9E 100%);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx;
  border-radius: 48rpx;
  border: none;
}

.ai-btn[disabled] {
  opacity: 0.5;
}

.ai-preview {
  margin: 0 32rpx 32rpx;
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 600;
}

.confidence {
  color: #52C41A;
  font-size: 24rpx;
}

.preview-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.preview-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.preview-item .label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
}

.value-input {
  flex: 1;
  padding: 12rpx 16rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.picker {
  flex: 1;
  padding: 12rpx 16rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.preview-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E9E 100%);
  color: white;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 32rpx;
}

.action-btn {
  flex: 1;
  background: white;
  padding: 32rpx 16rpx;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.action-btn .icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-btn .text {
  font-size: 24rpx;
  color: #666;
}

.category-section {
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-header .title {
  font-size: 32rpx;
  font-weight: 600;
}

.type-tabs {
  display: flex;
  background: #f5f5f5;
  padding: 4rpx;
  border-radius: 24rpx;
}

.type-tabs .tab {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 20rpx;
}

.type-tabs .tab.active {
  background: white;
  color: #FF6B9D;
  font-weight: 600;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.category-item {
  background: white;
  padding: 24rpx 8rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.cat-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.cat-name {
  font-size: 22rpx;
  color: #666;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 9999;
}

.modal-content {
  width: 100%;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 32rpx;
}

.amount-input-section {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 32rpx;
}

.currency {
  font-size: 48rpx;
  font-weight: 600;
  color: #FF6B9D;
  margin-right: 16rpx;
}

.amount-input {
  flex: 1;
  font-size: 64rpx;
  font-weight: 600;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.category-scroll {
  white-space: nowrap;
}

.cat-option {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  background: #f8f8f8;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.cat-option.selected {
  background: #FF6B9D;
  color: white;
}

.modal-footer {
  padding: 24rpx 32rpx 48rpx;
}

.submit-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E9E 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}
